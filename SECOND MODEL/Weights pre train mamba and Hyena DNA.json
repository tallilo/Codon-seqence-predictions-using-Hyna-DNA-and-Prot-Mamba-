{
  "experiment_id": "Weights pre train mamba and Hyena DNA",
  "optimizer": "adamw",
  "lr": 0.00001,
  "weight_decay": 0.01,
  "attention_dropout": 0.1,
  "mask_prob": 0.15,
  "span_length": 3,
  "prot_span_length": 1,
  "prot_mask_prob": 0.1,
  "dropout": 0.1,
  "lora_r": 64,
  "lora_alpha": 128,
  "target_modules": [
    "query",
    "key",
    "value",
    "dense",
    "fc1",
    "fc2",
    "in_proj",
    "x_proj",
    "dt_proj",
    "out_proj"
  ],
  "batch_size": 8,
  "grad_accum": 8,
  "epochs": 400,
  "warmup_steps": 800,
  "rate_adam_old_component": 0.25,
  "rate_adam_new_component": 5,
  "rate_LoRA": 4,
  "l_org_weight": 0.02,
  "l_pa_weight": 0.02,
  "l_aux_weight": 0.2
}
